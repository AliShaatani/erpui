{
  "name": "taq-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --base=/assets/taq_theme/TAQ_UI/ && npm run copy-html-entry",
    "lint": "oxlint",
    "preview": "vite preview",
    "copy-html-entry": "node -e \"const fs = require('fs'); fs.copyFileSync('../taq_theme/public/TAQ_UI/index.html', '../taq_theme/www/TAQ_UI.html')\""
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "frappe-react-sdk": "^1.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  },
  "resolutions": {
    "**/ws": "^8.21.0"
  }
}
